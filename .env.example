PORT=3000
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=localhost
DB_NAME=affiliate_auto_post

# Security Settings
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# Facebook API
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# Automation Settings (Random delay for auto-posting)
MIN_DELAY_MINUTES=15
MAX_DELAY_MINUTES=120

# System Configurations
ENABLE_AUTOMATION=true
MAX_POSTS_PER_DAY=50
POSTING_TIME_WINDOWS=08:00-22:00
ENABLE_TOP_PRODUCT_LOOP=true
ENABLE_AI_CAPTION=true
ENABLE_MULTI_PAGE=true
RETRY_LIMIT=3
QUEUE_CONCURRENCY=1
SAFE_MODE_ERROR_THRESHOLD=5
