PORT=3000
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=localhost
DB_NAME=affiliate_auto_post

# Security Settings
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# Facebook API
